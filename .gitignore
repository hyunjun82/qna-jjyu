# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# source data (API 수집 원본)
/source-data/

# scripts (일회성 유틸리티)
/scripts/

# tmp (임시 파일)
/tmp/

# IDE / 도구
.vscode/
.playwright-mcp/
.claude/

# 스크린샷
*.png
*.jpeg

# 임시 파일
nul
